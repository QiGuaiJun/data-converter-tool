HOST=0.0.0.0
PORT=8765
APP_AUTH_ENABLED=false
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password
# Railway: create one Volume and mount it to /data.
# Relative DATA_DIR/UPLOADS_DIR/EXPORTS_DIR will be stored inside RAILWAY_VOLUME_MOUNT_PATH.
DATA_DIR=./data
UPLOADS_DIR=./uploads
EXPORTS_DIR=./exports
APP_TIMEZONE=Asia/Shanghai
